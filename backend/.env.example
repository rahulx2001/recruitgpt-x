# ===== PII (optional — encrypts resume_text + email at rest) =====
# PII_ENCRYPTION_KEY=your-32-byte-secret-or-fernet-key

# ===== LLM (pick ONE — set LLM_PROVIDER_PREFERENCE=minimax for MiniMax-first) =====
LLM_PROVIDER_PREFERENCE=auto
NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=moonshotai/kimi-k2.6

# MiniMax M3 fallback
MINIMAX_API_KEY=
MINIMAX_BASE_URL=https://api.minimax.io/v1
MINIMAX_MODEL=MiniMax-M3

# Fallback providers
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# LLM_MODEL=gpt-4o-mini

# ===== Embeddings =====
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5
EMBEDDING_DIM=1024
# OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ===== Data Stores =====
# Production (Docker Compose)
DATABASE_URL=postgresql+asyncpg://recruitgpt:recruitgpt@localhost:5432/recruitgpt
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# Demo / zero-infra (uncomment instead)
# DATABASE_URL=sqlite+aiosqlite:///./recruitgpt.db

# ===== App =====
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000

# ===== Auth (set REQUIRE_AUTH=true in production) =====
REQUIRE_AUTH=false
DEFAULT_DEV_USER_ID=dev-user
# API_SECRET_KEY=your-long-random-secret
# CLERK_SECRET_KEY=sk_test_...
# CLERK_JWKS_URL=https://<your-clerk-domain>/.well-known/jwks.json
# CLERK_ISSUER=https://<your-clerk-domain>

# Rate limits (per user+IP per minute)
RATE_LIMIT_EXPENSIVE_PER_MINUTE=10
RATE_LIMIT_UPLOAD_PER_MINUTE=5
MAX_UPLOAD_BYTES=5242880

# ===== Frontend (Next.js / Vercel) =====
NEXT_PUBLIC_API_URL=http://localhost:8000

# ===== Clerk Auth (optional — app works without keys) =====
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...