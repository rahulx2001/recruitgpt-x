# Stage 3 reproduction image — CPU-only offline ranker (§5.3 / §3.2)
FROM python:3.11-slim

WORKDIR /app

# v5 ranker: bi-encoder artifact + cross-encoder rerank (graceful lexical fallback if artifacts missing)
COPY rank.py pyproject.toml requirements-ranker.txt ./
COPY challenge/ ./challenge/
COPY data/sample_candidates.json ./data/sample_candidates.json
COPY data/embeddings/candidate_ids.json data/embeddings/meta.json ./data/embeddings/
COPY scripts/validate_submission.py scripts/check_honeypots.py scripts/validate_submission_ids.py ./scripts/
COPY scripts/precompute_embeddings.py ./scripts/

RUN pip install --no-cache-dir -r requirements-ranker.txt

# Self-test on sample; mount candidates.jsonl + embeddings for full v5 run:
#   docker run -v $(pwd)/data/candidates.jsonl:/app/data/candidates.jsonl \
#     -v $(pwd)/data/embeddings:/app/data/embeddings recruitgpt-ranker \
#     python rank.py --candidates ./data/candidates.jsonl --out ./submission.csv
CMD ["python", "rank.py", "--self-test"]