# ===== PRODUCTION (Railway backend) =====
APP_ENV=production
REQUIRE_AUTH=true
AUTO_SEED_ON_STARTUP=true
USE_SEMANTIC_RANKING_WEIGHTS=false

DATABASE_URL=postgresql+asyncpg://user:pass@host:5432/recruitgpt
CORS_ORIGINS=https://your-app.vercel.app

NVIDIA_API_KEY=
# MINIMAX_API_KEY=

EMBEDDING_PROVIDER=local
QDRANT_URL=
QDRANT_API_KEY=

CLERK_SECRET_KEY=sk_live_...
CLERK_JWKS_URL=https://<clerk-domain>/.well-known/jwks.json
CLERK_ISSUER=https://<clerk-domain>

DEFAULT_DEV_USER_ID=dev-user
LLM_PROVIDER_PREFERENCE=auto
# PII_ENCRYPTION_KEY=generate-a-strong-secret
RATE_LIMIT_EXPENSIVE_PER_MINUTE=10